# ========================================
# DocPilot 工程 .gitignore
# ========================================

# ---------- Java / Spring Boot ----------
*.class
*.jar
*.war
*.ear
*.log
hs_err_pid*
replay_pid*

# Maven
target/
.mvn/
mvnw
mvnw.cmd
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties
.mvn/timing.properties
.mvn/wrapper/maven-wrapper.jar

# Gradle
.gradle/
build/
!gradle/wrapper/gradle-wrapper.jar
!**/src/main/**/build/
!**/src/test/**/build/

# IDE - IntelliJ
.idea/
*.iml
*.iws
*.ipr
out/

# IDE - Eclipse
.classpath
.project
.settings/
bin/

# IDE - VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# ---------- Node / Vue 3 ----------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Build outputs
dist/
dist-ssr/
*.local

# Cache
.cache/
.parcel-cache/
.eslintcache
.stylelintcache

# Coverage
coverage/
*.lcov
.nyc_output

# ---------- Environment ----------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
!.env.example

# ---------- Database ----------
*.db
*.sqlite
*.sqlite3
postgres-data/

# ---------- Logs ----------
logs/
*.log
!logs/.gitkeep

# ---------- OS ----------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ---------- Docker ----------
docker-compose.override.yml

# ---------- Test outputs ----------
test-output/
test-results/
allure-results/
allure-report/

# ---------- 临时文件 ----------
tmp/
*.tmp
*.bak
*.swp
*.swo

# ---------- 内部 / 敏感信息 ----------
# 注：API key / 数据库密码 / 第三方凭证 必须走 .env（已忽略）
# 绝不能 commit 到仓库

# ---------- 文档工具 ----------
# Mintlify
.mintlify/
# VuePress
.vuepress/dist/

# ---------- 其他 ----------
*.orig
*.rej
package-lock.json.bak
yarn.lock.bak
