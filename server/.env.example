# DocPilot 环境变量模板
# ⚠️ 这是模板文件，可提交到 git。真实凭证请复制为 .env 并填入。
#
# 使用方法：
#   cp .env.example .env
#   vim .env  # 填入真实值
#   chmod 600 .env

# ====================================
# 数据库（与 docker-compose.yml 一致）
# ====================================
POSTGRES_PASSWORD=docpil_dev_请改成你设置的密码

# ====================================
# LLM 配置（LangChain4j）
# ====================================
# LLM API endpoint（OpenAI 兼容）
LLM_BASE_URL=https://api.minimax.io/anthropic

# LLM API key（问项目负责人拿）
LLM_API_KEY=sk-请填入真实 key

# 模型名（与提供商支持的模型列表一致）
LLM_MODEL=MiniMax-M3

# ====================================
# Fallback LLM（Qwen - 通义千问，设计 04 § 11.4）
# ====================================
# 主备选择：m3（默认）或 qwen
SELECT_LLM=m3

# Qwen 配置（设 QWEN_ENABLED=true 才生效）
QWEN_ENABLED=false
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=sk-请填入 qwen key
QWEN_MODEL=qwen-plus
